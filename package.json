{
  "name": "public-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "docusaurus": "docusaurus",
    "fetch-api": "tsx scripts/fetch-api-schema.ts",
    "enrich-api": "tsx scripts/enrich-api-spec.ts",
    "extract-schemas": "tsx scripts/extract-schema.ts SchemaWebhook PaymentOperationResponses",
    "inject-mcp-hints": "tsx scripts/inject-mcp-hints.ts",
    "gen-api": "npm run enrich-api && npx docusaurus clean-api-docs ottuApi && npx docusaurus gen-api-docs ottuApi && npm run extract-schemas && npm run inject-mcp-hints",
    "update-api": "npm run fetch-api && npm run gen-api",
    "start": "docusaurus start",
    "build": "docusaurus build && cp -r build/mcp build/_mcp-data",
    "swizzle": "docusaurus swizzle",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "webhook": "PORT=8090 node mcp-server/server.mjs",
    "webhook:local": "PORT=8090 node --env-file-if-exists=.env.local mcp-server/server.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-mermaid": "^3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-markdown-source-plugin": "^2.2.5",
    "docusaurus-plugin-mcp-server": "^0.13.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.4.0",
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.0",
    "@types/js-yaml": "^4.0.9",
    "docusaurus-plugin-openapi-docs": "^5.0.0",
    "docusaurus-theme-openapi-docs": "^5.1.0",
    "openapi-to-postmanv2": "^6.0.0",
    "patch-package": "^8.0.1",
    "postman-code-generators": "^2.1.0",
    "postman-collection": "^5.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": "20.19.6"
  }
}
